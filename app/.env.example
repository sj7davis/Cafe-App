# ── Database ───────────────────────────────────────────────────
# Local MySQL:
DATABASE_URL=mysql://root:password@localhost:3306/b1_platform
# PlanetScale / TiDB Cloud / Railway MySQL:
# DATABASE_URL=mysql://user:password@host:port/database

# ── Auth Secrets ───────────────────────────────────────────────
# Generate strong secrets for production:  openssl rand -hex 32
JWT_SECRET=change-me-in-production
PLATFORM_ADMIN_SECRET=change-me-in-production

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Square POS (optional) ──────────────────────────────────────
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENV=sandbox
# API_URL=https://your-domain.com.au   # used for Square OAuth redirect

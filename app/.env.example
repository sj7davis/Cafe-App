# ── Database ───────────────────────────────────────────────────
# Local dev: run `npm run db:local` (embedded Postgres) and use:
DATABASE_URL=postgres://postgres:password@localhost:5432/b1_platform
# Hosted Postgres (Railway / Neon / Supabase):
# DATABASE_URL=postgres://user:password@host:port/database

# ── Auth Secrets ───────────────────────────────────────────────
# Generate strong secrets for production:  openssl rand -hex 32
# JWT_SECRET also signs the OAuth `state` parameter for all integrations,
# so it MUST be a strong, stable secret in production.
JWT_SECRET=change-me-in-production
PLATFORM_ADMIN_SECRET=change-me-in-production

# ── Server ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Public base URL — used to build every OAuth redirect_uri below.
# Locally this defaults to http://localhost:3000; set explicitly in prod.
APP_URL=http://localhost:3000

# ── Integrations (OAuth2) ──────────────────────────────────────
# One platform-registered app per provider; each cafe (tenant) grants
# access to their own account via OAuth. Register these exact redirect
# URIs in each provider's developer portal (swap localhost for APP_URL):

# Square POS — redirect: {APP_URL}/api/square/callback
SQUARE_APP_ID=
SQUARE_APP_SECRET=
SQUARE_ENV=sandbox            # sandbox | production

# Xero (accounting) — redirect: {APP_URL}/api/xero/callback
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Lightspeed / Kounta POS — redirect: {APP_URL}/api/lightspeed/callback
LIGHTSPEED_CLIENT_ID=
LIGHTSPEED_CLIENT_SECRET=

# Google My Business — redirect: {APP_URL}/api/gmb/callback
# OAuth client needs the business.manage scope enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Integrations (API key — vendor has no OAuth server) ────────
# Impos and Tyro are connected with per-venue API keys entered in the
# dashboard; no platform-level credentials are required here.

# ── Payments (Stripe) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=3
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# ── Email / SMS / Push (optional) ──────────────────────────────
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
